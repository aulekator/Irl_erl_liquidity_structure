//@version=5
indicator("IRL → ERL Liquidity & Structure Map", shorttitle="IRL-ERL", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ============================================================
// IRL -> ERL framework
//  1. ERL levels        = prior swing highs/lows (liquidity pools)
//  2. Sweep              = wick through an ERL level, close back inside
//  3. MSS (structure shift) = close breaks the internal pivot formed
//                              after the swept level, confirming direction
//  4. IRL zone           = order block / FVG left by the impulse leg
//                              that caused the MSS -> your entry
//  5. Target             = nearest opposite, still-unswept ERL level
// ============================================================

// ───────────────────────── Inputs ─────────────────────────
swingLen     = input.int(5, "Swing pivot length", minval=1, group="Structure")
maxPoolAge   = input.int(300, "Max bars to keep an unswept ERL level", minval=20, group="Structure")
maxMSSWait   = input.int(60, "Max bars to wait for MSS after a sweep", minval=5, group="Structure")
obLookback   = input.int(12, "Order block / FVG search window (bars)", minval=1, maxval=40, group="IRL zones")
zoneExtend   = input.int(20, "Bars to extend IRL zone boxes forward", minval=1, group="IRL zones")

showPools    = input.bool(true, "Show unswept ERL levels", group="Display")
showSweeps   = input.bool(true, "Show liquidity sweeps", group="Display")
showMSS      = input.bool(true, "Show market structure shift", group="Display")
showOB       = input.bool(true, "Show order block (IRL)", group="Display")
showFVG      = input.bool(true, "Show fair value gap (IRL)", group="Display")
showTarget   = input.bool(true, "Project target to opposite ERL", group="Display")

colBull      = input.color(color.new(color.teal, 0),    "Bullish accent", group="Colors")
colBear      = input.color(color.new(color.maroon, 0),  "Bearish accent", group="Colors")
colERL       = input.color(color.new(color.gray, 40),   "ERL level", group="Colors")

// ───────────────────────── Types ─────────────────────────
type Pivot
    float price
    int   barIdx
    bool  swept
    line  ln

var Pivot[] swingHighs = array.new<Pivot>()   // potential BSL / ERL above price
var Pivot[] swingLows  = array.new<Pivot>()   // potential SSL / ERL below price

// pending sweep -> MSS trackers (most recent unresolved cycle per side)
var bool  bearPending   = false
var int   bearSweepBar  = na
var float bearStructLvl = na

var bool  bullPending   = false
var int   bullSweepBar  = na
var float bullStructLvl = na

// ───────────────────────── Helper functions ─────────────────────────
// last opposite-color candle before the break bar = the order block
f_findOB(bearish, fromBar, toBar) =>
    float obHigh = na
    float obLow  = na
    int   obBar  = na
    lookStart = math.max(fromBar, toBar - obLookback)
    for b = toBar to lookStart by 1
        c_open  = open[bar_index - b]
        c_close = close[bar_index - b]
        c_high  = high[bar_index - b]
        c_low   = low[bar_index - b]
        if bearish and c_close > c_open
            obHigh := c_high
            obLow  := c_low
            obBar  := b
            break
        if not bearish and c_close < c_open
            obHigh := c_high
            obLow  := c_low
            obBar  := b
            break
    [obHigh, obLow, obBar]

// 3-candle fair value gap inside the impulse leg
f_findFVG(bearish, fromBar, toBar) =>
    float top    = na
    float bot    = na
    int   fvgBar = na
    lookStart = math.min(toBar, math.max(fromBar + 2, toBar - obLookback))
    for b = toBar to lookStart by 1
        h2 = high[bar_index - (b - 2)]
        l2 = low[bar_index - (b - 2)]
        h0 = high[bar_index - b]
        l0 = low[bar_index - b]
        if bearish and l2 > h0
            top    := l2
            bot    := h0
            fvgBar := b
            break
        if not bearish and h2 < l0
            top    := l0
            bot    := h2
            fvgBar := b
            break
    [top, bot, fvgBar]

// nearest unswept pivot on the other side of price = the ERL target
f_nearestBelow(arr, refPrice) =>
    float best = na
    if array.size(arr) > 0
        for i = 0 to array.size(arr) - 1
            Pivot pv = array.get(arr, i)
            if not pv.swept and pv.price < refPrice
                if na(best) or pv.price > best
                    best := pv.price
    best

f_nearestAbove(arr, refPrice) =>
    float best = na
    if array.size(arr) > 0
        for i = 0 to array.size(arr) - 1
            Pivot pv = array.get(arr, i)
            if not pv.swept and pv.price > refPrice
                if na(best) or pv.price < best
                    best := pv.price
    best

// ───────────────────────── Pivot capture ─────────────────────────
ph = ta.pivothigh(swingLen, swingLen)
pl = ta.pivotlow(swingLen, swingLen)

if not na(ph)
    Pivot p = Pivot.new(ph, bar_index - swingLen, false, na)
    if showPools
        p.ln := line.new(p.barIdx, p.price, bar_index, p.price, color=colERL, style=line.style_dashed, extend=extend.right)
    array.push(swingHighs, p)

if not na(pl)
    Pivot p2 = Pivot.new(pl, bar_index - swingLen, false, na)
    if showPools
        p2.ln := line.new(p2.barIdx, p2.price, bar_index, p2.price, color=colERL, style=line.style_dashed, extend=extend.right)
    array.push(swingLows, p2)

// prune stale unswept pivots
f_prune(arr) =>
    if array.size(arr) > 0
        for i = array.size(arr) - 1 to 0 by 1
            Pivot pv = array.get(arr, i)
            if bar_index - pv.barIdx > maxPoolAge and not pv.swept
                if not na(pv.ln)
                    line.delete(pv.ln)
                array.remove(arr, i)

f_prune(swingHighs)
f_prune(swingLows)

// ───────────────────────── Sweep detection ─────────────────────────
// BSL swept (buy-side liquidity above an old high) -> bearish setup
if array.size(swingHighs) > 0
    for i = array.size(swingHighs) - 1 to 0 by 1
        Pivot pv = array.get(swingHighs, i)
        if not pv.swept and high > pv.price and close < pv.price
            pv.swept := true
            if not na(pv.ln)
                line.set_extend(pv.ln, extend.none)
                line.set_x2(pv.ln, bar_index)
            if showSweeps
                label.new(bar_index, high, "Sweep BSL", style=label.style_label_down, color=colBear, textcolor=color.white, size=size.small)
            float structLvl = na
            if array.size(swingLows) > 0
                for j = array.size(swingLows) - 1 to 0 by 1
                    Pivot lv = array.get(swingLows, j)
                    if lv.barIdx > pv.barIdx
                        structLvl := lv.price
                        break
            if not na(structLvl)
                bearPending   := true
                bearSweepBar  := bar_index
                bearStructLvl := structLvl

// SSL swept (sell-side liquidity below an old low) -> bullish setup
if array.size(swingLows) > 0
    for i = array.size(swingLows) - 1 to 0 by 1
        Pivot pv = array.get(swingLows, i)
        if not pv.swept and low < pv.price and close > pv.price
            pv.swept := true
            if not na(pv.ln)
                line.set_extend(pv.ln, extend.none)
                line.set_x2(pv.ln, bar_index)
            if showSweeps
                label.new(bar_index, low, "Sweep SSL", style=label.style_label_up, color=colBull, textcolor=color.white, size=size.small)
            float structLvl = na
            if array.size(swingHighs) > 0
                for j = array.size(swingHighs) - 1 to 0 by 1
                    Pivot hv = array.get(swingHighs, j)
                    if hv.barIdx > pv.barIdx
                        structLvl := hv.price
                        break
            if not na(structLvl)
                bullPending   := true
                bullSweepBar  := bar_index
                bullStructLvl := structLvl

// expire stale pending sweeps that never got an MSS
if bearPending and bar_index - bearSweepBar > maxMSSWait
    bearPending := false
if bullPending and bar_index - bullSweepBar > maxMSSWait
    bullPending := false

// ───────────────────────── MSS confirmation + IRL zone ─────────────────────────
if bearPending and close < bearStructLvl
    if showMSS
        line.new(bearSweepBar, bearStructLvl, bar_index, bearStructLvl, color=colBear, width=1)
        label.new(bar_index, bearStructLvl, "MSS \u2193", style=label.style_label_down, color=colBear, textcolor=color.white, size=size.small)

    [obHigh, obLow, obBar] = f_findOB(true, bearSweepBar, bar_index)
    if showOB and not na(obHigh)
        box.new(obBar, obHigh, bar_index + zoneExtend, obLow, border_color=colBear, bgcolor=color.new(colBear, 85), text="IRL (OB)", text_color=colBear, text_size=size.small)

    [fTop, fBot, fBar] = f_findFVG(true, bearSweepBar, bar_index)
    if showFVG and not na(fTop)
        box.new(fBar - 2, fTop, bar_index + zoneExtend, fBot, border_color=colBear, bgcolor=color.new(colBear, 90), text="IRL (FVG)", text_color=colBear, text_size=size.small)

    if showTarget
        tgt = f_nearestBelow(swingLows, close)
        if not na(tgt)
            line.new(bar_index, close, bar_index + zoneExtend, tgt, color=colBear, style=line.style_dotted, width=1)
            label.new(bar_index + zoneExtend, tgt, "ERL target", style=label.style_label_up, color=color.new(colBear, 70), textcolor=colBear, size=size.small)

    alert("Bearish MSS confirmed - IRL entry zone formed", alert.freq_once_per_bar_close)
    bearPending := false

if bullPending and close > bullStructLvl
    if showMSS
        line.new(bullSweepBar, bullStructLvl, bar_index, bullStructLvl, color=colBull, width=1)
        label.new(bar_index, bullStructLvl, "MSS \u2191", style=label.style_label_up, color=colBull, textcolor=color.white, size=size.small)

    [obHigh2, obLow2, obBar2] = f_findOB(false, bullSweepBar, bar_index)
    if showOB and not na(obHigh2)
        box.new(obBar2, obHigh2, bar_index + zoneExtend, obLow2, border_color=colBull, bgcolor=color.new(colBull, 85), text="IRL (OB)", text_color=colBull, text_size=size.small)

    [fTop2, fBot2, fBar2] = f_findFVG(false, bullSweepBar, bar_index)
    if showFVG and not na(fTop2)
        box.new(fBar2 - 2, fTop2, bar_index + zoneExtend, fBot2, border_color=colBull, bgcolor=color.new(colBull, 90), text="IRL (FVG)", text_color=colBull, text_size=size.small)

    if showTarget
        tgt2 = f_nearestAbove(swingHighs, close)
        if not na(tgt2)
            line.new(bar_index, close, bar_index + zoneExtend, tgt2, color=colBull, style=line.style_dotted, width=1)
            label.new(bar_index + zoneExtend, tgt2, "ERL target", style=label.style_label_down, color=color.new(colBull, 70), textcolor=colBull, size=size.small)

    alert("Bullish MSS confirmed - IRL entry zone formed", alert.freq_once_per_bar_close)
    bullPending := false

// ───────────────────────── Alert conditions (for the Alert dialog) ─────────────────────────
alertcondition(bearPending and close[1] >= bearStructLvl and close < bearStructLvl, title="Bearish MSS", message="Bearish market structure shift confirmed - IRL zone should be forming")
alertcondition(bullPending and close[1] <= bullStructLvl and close > bullStructLvl, title="Bullish MSS", message="Bullish market structure shift confirmed - IRL zone should be forming")
